{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:allNonMajor",
    ":dependencyDashboard",
    ":semanticCommits",
    ":separatePatchReleases"
  ],
  "assignees": ["thomascarter613"],
  "reviewers": ["thomascarter613"],
  "schedule": ["before 9am on Monday"],
  "timezone": "UTC",
  "prHourlyLimit": 5,
  "prConcurrentLimit": 10,
  "packageRules": [
    {
      "description": "Automerge patch updates for devDependencies only",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "Never automerge major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "major-update"]
    },
    {
      "description": "Never automerge production dependency updates",
      "matchDepTypes": ["dependencies"],
      "automerge": false,
      "labels": ["dependencies"]
    },
    {
      "description": "Group all Biome updates",
      "matchPackageNames": ["@biomejs/biome"],
      "groupName": "biome"
    },
    {
      "description": "Group all TypeScript updates",
      "matchPackageNames": ["typescript"],
      "groupName": "typescript"
    },
    {
      "description": "Group all Vitest updates",
      "matchPackagePatterns": ["^vitest", "^@vitest/"],
      "groupName": "vitest"
    },
    {
      "description": "Group all Turborepo updates",
      "matchPackageNames": ["turbo"],
      "groupName": "turborepo"
    }
  ],
  "commitMessagePrefix": "chore(deps):",
  "labels": ["dependencies"]
}
