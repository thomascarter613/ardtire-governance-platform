# =============================================================
# Ardtire Governance Platform — Environment Configuration
# Copy this file to .env and fill in values for local development.
# Never commit .env to version control.
# =============================================================

# Application
NODE_ENV=development
LOG_LEVEL=info

# API
API_PORT=3001
API_HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ardtire_dev
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM_PUBLIC=ardtire-public
KEYCLOAK_REALM_MEMBER=ardtire-member
KEYCLOAK_REALM_ADMIN=ardtire-admin
KEYCLOAK_CLIENT_ID=gov-api
KEYCLOAK_CLIENT_SECRET=changeme-local-dev

# JWT
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
JWT_ALGORITHM=RS256

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=changeme-local-dev

# Email (Mailpit for local dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@ardtiresociety.org
SMTP_SECURE=false

# Audit
AUDIT_LOG_RETENTION_DAYS=3650

# OpenTelemetry
# Set OTEL_ENABLED=false to disable OTel instrumentation entirely (useful for bare-bones local runs)
OTEL_ENABLED=true
OTEL_SERVICE_NAME=gov-api
OTEL_SERVICE_VERSION=0.0.0
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
